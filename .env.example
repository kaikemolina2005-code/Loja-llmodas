# =============================================
# CONFIGURACOES DA LOJA - PREENCHA TUDO ABAIXO
# =============================================

# URL pública do site (sem barra no final)
NEXT_PUBLIC_STORE_URL=https://seudominio.com.br

# ---- ECWID ----
# ID da sua loja Ecwid (encontrado em: Ecwid > Configurações > Geral)
NEXT_PUBLIC_ECWID_STORE_ID=SEU_ECWID_STORE_ID

# Token da API Ecwid (Ecwid > Apps > API)
ECWID_API_TOKEN=SEU_ECWID_API_TOKEN

# ---- CLERK (autenticação) ----
# Encontrado em: clerk.com > seu projeto > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Rotas de redirecionamento Clerk (não altere)
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/minha-conta
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/minha-conta
